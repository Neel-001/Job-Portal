# MongoDB Connection String
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/

# Server Port
PORT=8000

# JWT Secret Key (use a long, random string in production)
SECRET_KEY=your_secret_key_here

# Cloudinary Credentials (for file/image uploads)
# Sign up at https://cloudinary.com to get these
CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret

# Backend Base URL (update to your deployed URL or http://localhost:8000 for local dev)
VITE_REACT_APP_BACKEND_BASEURL=https://your-backend.onrender.com
